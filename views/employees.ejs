<!DOCTYPE html>
<html lang="zxx">

<head>
    <meta charset="utf-8">
    <meta http-equiv="x-ua-compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="keyword" content="">
    <meta name="author" content="theme_ocean">
    <!--! The above 6 meta tags *must* come first in the head; any other head content must come *after* these tags !-->
    <!--! BEGIN: Apps Title-->
    <title>B-Leave || <%= title %>
    </title>
    <!--! END:  Apps Title-->
    <!--! BEGIN: Favicon-->
    <link rel="shortcut icon" type="image/x-icon" href="/assets/images/favicon.ico">
    <!--! END: Favicon-->
    <!--! BEGIN: Bootstrap CSS-->
    <link rel="stylesheet" type="text/css" href="/assets/css/bootstrap.min.css">
    <!--! END: Bootstrap CSS-->
    <!--! BEGIN: Vendors CSS-->
    <link rel="stylesheet" type="text/css" href="/assets/vendors/css/vendors.min.css">
    <link rel="stylesheet" type="text/css" href="/assets/vendors/css/select2.min.css">
    <link rel="stylesheet" type="text/css" href="/assets/vendors/css/select2-theme.min.css">
    <link rel="stylesheet" type="text/css" href="/assets/vendors/css/jquery.time-to.min.css">
    <!--! END: Vendors CSS-->
    <!--! BEGIN: Custom CSS-->
    <link rel="stylesheet" type="text/css" href="/assets/css/theme.min.css">
    <!--! END: Custom CSS-->
    <!--! HTML5 shim and Respond.js for IE8 support of HTML5 elements and media queries !-->
    <!--! WARNING: Respond.js doesn"t work if you view the page via file: !-->
    <!--[if lt IE 9]>
			<script src="https:oss.maxcdn.com/html5shiv/3.7.2/html5shiv.min.js"></script>
			<script src="https:oss.maxcdn.com/respond/1.4.2/respond.min.js"></script>
		<![endif]-->
</head>


<body>
    <%- include('partials/sidebar.ejs') %>
        <%- include('partials/header.ejs') %>
            <main class="nxl-container">
                <div class="nxl-content">
                    <div class="page-header">
                        <div class="page-header-left d-flex align-items-center">
                            <div class="page-header-title">
                                <h5 class="m-b-10">Be-Leave</h5>
                            </div>
                            <ul class="breadcrumb">
                                <li class="breadcrumb-item">Employee</li>
                                <li class="breadcrumb-item">List</li>
                            </ul>
                        </div>
                        <div class="page-header-right ms-auto">
                            <div class="page-header-right-items">
                                <div class="d-flex d-md-none">
                                    <a href="javascript:void(0)" class="page-header-right-close-toggle">
                                        <i class="feather-arrow-left me-2"></i>
                                        <span>Back</span>
                                    </a>
                                </div>
                            </div>
                            <div class="d-md-none d-flex align-items-center">
                                <a href="javascript:void(0)" class="page-header-right-open-toggle">
                                    <i class="feather-align-right fs-20"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- [ page-header ] end -->
                    <div class="bg-white py-3 border-bottom rounded-0 p-md-0 mb-0">
                        <div class="d-md-none d-flex align-items-center justify-content-between">
                            <a href="javascript:void(0)" class="page-content-left-open-toggle">
                                <i class="feather-align-left fs-20"></i>
                            </a>
                        </div>
                    </div>
                    <!-- [ Main Content ] start -->
                    <div class="main-content">
                        <div class="tab-content">
                            <div class="tab-pane fade active show" id="overviewTab">
                                <div class="row">

                                    <div class="col-12">
                                        <div class="card stretch stretch-full">
                                            <div class="card-header">
                                                <div class="row w-100">
                                                    <div class="col-md-2">
                                                        <h4 class="header">Leave Plan</h4>
                                                    </div>
                                                    <div
                                                        class="col-10 task-header d-md-flex align-items-center justify-content-between">
                                                        <div class="me-4 w-75">
                                                            <div class="d-flex align-items-center">
                                                                <label for="lineFilter"
                                                                    class="form-label ms-3">Line:</label>
                                                                <select class="form-select mx-3" name="lineFilter"
                                                                    id="lineFilter">
                                                                    <% lineList.forEach(line=> { %>
                                                                        <% if (line==='NULL' ) { %>
                                                                            <option value="<%= line %>" selected>
                                                                                <%= line %>
                                                                            </option>
                                                                            <% } else { %>
                                                                                <option value="<%= line %>">
                                                                                    <%= line %>
                                                                                </option>
                                                                                <% } %>
                                                                                    <% }) %>
                                                                </select>
                                                                <label for="departementFilter"
                                                                    class="form-label ms-3">Departement:</label>
                                                                <select class="form-select mx-3"
                                                                    name="departementFilter" id="departementFilter">
                                                                    <% departementList.forEach(function(departement) {
                                                                        %>
                                                                        <% if(departement==='HR' ) { %>
                                                                            <option value="<%= departement %>" selected>
                                                                                <%= departement %>
                                                                            </option>
                                                                            <% } else { %>
                                                                                <option value="<%= departement %>">
                                                                                    <%= departement %>
                                                                                </option>
                                                                                <% } %>
                                                                                    <% }); %>
                                                                </select>
                                                            </div>
                                                        </div>
                                                        <div class="">
                                                            <div class="d-flex gap-2">
                                                                <% if(user.role !=="USER" ) { %>
                                                                    <a href="/leave/new-leave" class="btn btn-success"
                                                                        title="New leave">
                                                                        <i class="feather-plus me-2"></i>
                                                                        <span>New Leave</span>
                                                                    </a>
                                                                    <% } %>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card-body custom-card-action p-0">
                                                <div class="table-responsive mb-3">
                                                    <table class="table table-hover mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>Matricule</th>
                                                                <th>Full Name</th>
                                                                <th>Date of birth</th>
                                                                <th>Departement</th>
                                                                <th>Section</th>
                                                                <th>Occupation</th>
                                                                <th>Line</th>
                                                                <% if(user.role !=="PAYROLL" ) { %>
                                                                    <th class="text-center">Action</th>
                                                                    <% } %>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <% employees.forEach((employee, index)=> { %>
                                                                <tr>
                                                                    <td>
                                                                        <%= employee.matricule %>
                                                                    </td>
                                                                    <td>
                                                                        <div
                                                                            class="fs-11 d-flex justify-content-between mb-1">
                                                                            <%= employee.fullname %>
                                                                        </div>
                                                                    </td>
                                                                    <td>
                                                                        <div class="hstack gap-3">
                                                                            <%= employee.date_of_birth %>
                                                                        </div>
                                                                    </td>
                                                                    <td>
                                                                        <div class="hstack gap-3">
                                                                            <%= employee.department %>
                                                                        </div>
                                                                    </td>
                                                                    <td>
                                                                        <div class="hstack gap-3">
                                                                            <%= employee.section %>
                                                                        </div>
                                                                    </td>
                                                                    <td>
                                                                        <div class="hstack gap-3">
                                                                            <%= employee.occupation %>
                                                                        </div>
                                                                    </td>
                                                                    <td>
                                                                        <div class="hstack gap-3">
                                                                            <%= employee.line %>
                                                                        </div>
                                                                    </td>
                                                                    <% if(user.role !=="PAYROLL" ) { %>
                                                                        <td class="text-center">
                                                                            <a href="/employee/edit-employee/<%= employee.id %>"
                                                                                class="btn btn-primary btn-sm">
                                                                                <i class="feather-edit"></i>
                                                                            </a>
                                                                            <a href="/employee/delete-employee/<%= employee.id %>"
                                                                                class="btn btn-danger btn-sm">
                                                                                <i class="feather-trash"></i>
                                                                            </a>
                                                                        </td>
                                                                        <% } %>
                                                                </tr>
                                                                <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <%- include('partials/footer.ejs') %>