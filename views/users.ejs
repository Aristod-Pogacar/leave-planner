<body>
    <%- include('partials/sidebar.ejs') %>
        <%- include('partials/header.ejs') %>
            <main class="nxl-container">
                <div class="nxl-content">
                    <div class="page-header">
                        <div class="page-header-left d-flex align-items-center">
                            <div class="page-header-title">
                                <h5 class="m-b-10">Be-Leave</h5>
                            </div>
                            <ul class="breadcrumb">
                                <li class="breadcrumb-item">Users</li>
                                <li class="breadcrumb-item">List</li>
                            </ul>
                        </div>
                        <div class="page-header-right ms-auto">
                            <div class="page-header-right-items">
                                <div class="d-flex d-md-none">
                                    <a href="javascript:void(0)" class="page-header-right-close-toggle">
                                        <i class="feather-arrow-left me-2"></i>
                                        <span>Back</span>
                                    </a>
                                </div>
                            </div>
                            <div class="d-md-none d-flex align-items-center">
                                <a href="javascript:void(0)" class="page-header-right-open-toggle">
                                    <i class="feather-align-right fs-20"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                    <!-- [ page-header ] end -->
                    <div class="bg-white py-3 border-bottom rounded-0 p-md-0 mb-0">
                        <div class="d-md-none d-flex align-items-center justify-content-between">
                            <a href="javascript:void(0)" class="page-content-left-open-toggle">
                                <i class="feather-align-left fs-20"></i>
                            </a>
                        </div>
                    </div>
                    <!-- [ Main Content ] start -->
                    <div class="main-content">
                        <div class="tab-content">
                            <div class="tab-pane fade active show" id="overviewTab">
                                <div class="row">

                                    <div class="col-12">
                                        <div class="card stretch stretch-full">
                                            <div class="card-header">
                                                <h5 class="card-title">User list</h5>
                                                <div
                                                    class="col-10 task-header d-md-flex align-items-center justify-content-between">
                                                    <div class="me-4 w-75">
                                                    </div>
                                                    <div class="">
                                                        <div class="d-flex gap-2">
                                                            <% if(user.role !=="PAYROLL" ) { %>
                                                                <a href="/user/new-user" class="btn btn-primary"
                                                                    title="New user">
                                                                    <i class="feather-plus me-2"></i>
                                                                    <span>New user</span>
                                                                </a>
                                                                <% } %>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="card-body custom-card-action p-0">
                                                <div class="table-responsive mb-3">
                                                    <table class="table table-hover mb-0">
                                                        <thead>
                                                            <tr>
                                                                <th>#</th>
                                                                <th>First Name</th>
                                                                <th>Last Name</th>
                                                                <th>Site</th>
                                                                <th>Phone</th>
                                                                <th>Email</th>
                                                                <th class="text-center">Role</th>
                                                                <% if(user.role !=="PAYROLL" ) { %>
                                                                    <th class="text-center">Action</th>
                                                                    <% } %>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <!-- <tr>
                                                                <td>1</td>
                                                                <td>
                                                                    <div
                                                                        class="fs-11 d-flex justify-content-between mb-1">
                                                                        Super</div>
                                                                </td>
                                                                <td>
                                                                    <div class="hstack gap-3">
                                                                        Admin
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="hstack gap-3">
                                                                        ADMIN
                                                                    </div>
                                                                </td>
                                                                <td>
                                                                    <div class="hstack gap-3">
                                                                        -
                                                                    </div>
                                                                </td>
                                                                <td>stagedp@aquarabe.mg</td>
                                                                <td class="text-center"><span
                                                                        class="badge bg-soft-danger text-danger">Super
                                                                        Admin</span>
                                                                </td>
                                                                <% if(user.role !=="PAYROLL" ) { %>
                                                                    <td class="text-center">
                                                                    </td>
                                                                    <% } %>
                                                            </tr> -->
                                                            <% var i=1 %>
                                                                <% users.forEach(users=> { var roleColor="primary"
                                                                    if (users.role==userRole.SUPERADMIN)
                                                                    {
                                                                    roleColor="danger"
                                                                    } else if (users.role==userRole.ADMIN) {
                                                                    roleColor="warning"
                                                                    } else if (users.role==userRole.PAYROLL) {
                                                                    roleColor="info"
                                                                    } else if (users.role==userRole.USER) {
                                                                    roleColor="primary"
                                                                    } %>
                                                                    <tr>
                                                                        <td>
                                                                            <%= i++ %>
                                                                        </td>
                                                                        <td>
                                                                            <div
                                                                                class="fs-11 d-flex justify-content-between mb-1">
                                                                                <%= users.firstName %>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <div class="hstack gap-3">
                                                                                <%= users.name %>
                                                                            </div>
                                                                        </td>
                                                                        <td>
                                                                            <% const maValeur=users.site ; const
                                                                                index=allValues.indexOf(maValeur); const
                                                                                maCle=(index !==-1) ? keys[index]
                                                                                : "Inconnu" ; %>
                                                                                <div class="hstack gap-3">
                                                                                    <%= maCle %>
                                                                                </div>
                                                                        </td>
                                                                        <td>
                                                                            <%= users.phone %>
                                                                        </td>
                                                                        <td>
                                                                            <%= users.email %>
                                                                        </td>
                                                                        <td class="text-center">
                                                                            <span
                                                                                class="badge bg-soft-<%= roleColor %> text-<%= roleColor %>">
                                                                                <%= users.role %>
                                                                            </span>
                                                                        </td>
                                                                        <td class="text-center">
                                                                            <% if(user.role !=="PAYROLL" &&
                                                                                allowedSites.includes(users.site) &&
                                                                                users.role !==userRole.SUPERADMIN ) { %>
                                                                                <div
                                                                                    class="hstack gap-2 justify-content-center">
                                                                                    <a href="/user/edit-user/<%= users.id %>"
                                                                                        class="avatar-text avatar-md"
                                                                                        data-bs-toggle="tooltip"
                                                                                        title="Edit">
                                                                                        <i class="feather-edit"></i>
                                                                                    </a>
                                                                                    <a href="/user/delete-user/<%= users.id %>"
                                                                                        class="avatar-text avatar-md"
                                                                                        data-bs-toggle="tooltip"
                                                                                        title="Delete">
                                                                                        <i class="feather-trash"></i>
                                                                                    </a>
                                                                                </div>
                                                                                <% } %>
                                                                        </td>
                                                                    </tr>
                                                                    <% }) %>
                                                        </tbody>
                                                    </table>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <%- include('partials/footer.ejs') %>